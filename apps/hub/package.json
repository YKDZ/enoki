{
  "name": "@enoki/hub",
  "private": true,
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "db:generate": "pnpm run db:generate:core && pnpm run db:generate:official-metrics",
    "db:generate:core": "drizzle-kit generate --config drizzle.config.ts",
    "db:generate:official-metrics": "drizzle-kit generate --config drizzle.official-metrics.config.ts",
    "db:push": "drizzle-kit push --config drizzle.config.ts && drizzle-kit push --config drizzle.official-metrics.config.ts",
    "start": "node dist/src/server.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.build.json --noEmit && tsc -p tsconfig.typecheck.json"
  },
  "dependencies": {
    "@enoki/api-client": "workspace:*",
    "@enoki/proto": "workspace:*",
    "@hono/node-server": "^2.0.5",
    "@hono/node-ws": "^1.3.1",
    "@hono/valibot-validator": "^0.6.1",
    "drizzle-orm": "1.0.0-beta.22",
    "hono": "^4.12.26",
    "valibot": "^1.4.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.0.10",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "1.0.0-beta.22",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
